OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-5.4-nano
OPENAI_MODEL_SYNTHESIS=gpt-5.4-mini
FIRECRAWL_API_KEY=
AHREFS_API_KEY=

# Optional only. The default real stack uses Firecrawl for web/Reddit discovery.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:ai-search-opportunity-report:v0.1.0 (by /u/launchclub)
# MEMES_AI_API_URL=
MEMES_AI_API_KEY=
# SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
REPORT_RATE_LIMIT_SALT=change-me
# Use a stable random value of at least 32 characters. Never expose it to browser code.
REPORT_ACCESS_TOKEN_SECRET=
REPORT_ACCESS_TOKEN_TTL_DAYS=365
REPORT_REVOKED_TOKEN_RETENTION_DAYS=90
REPORT_ACCESS_EVENT_RETENTION_MONTHS=13
REPORT_RECOVERY_TOKEN_TTL_MINUTES=15
REPORT_RECOVERY_TOKEN_RETENTION_DAYS=90
WORKFLOW_LEASE_SECONDS=120
WORKFLOW_OUTBOX_LEASE_SECONDS=60
WORKFLOW_MAX_ATTEMPTS=4
# Required only for the server-side administrator CLI. Use 32+ random characters.
WORKFLOW_ADMIN_SECRET=
# Netlify Async Workloads management key. Server-side only.
AWL_API_KEY=
REPORT_REQUEST_COOLDOWN_HOURS=24
REPORT_DOMAIN_COOLDOWN_MINUTES=60
REPORT_CONTACT_COOLDOWN_MINUTES=60
REPORT_MAX_ACTIVE_PER_COMPANY=2
REPORT_MAX_ACTIVE_PER_CONTACT=2
REPORT_RATE_LIMIT_WINDOW_MINUTES=60
REPORT_RATE_LIMIT_IP_COUNT=10
REPORT_RATE_LIMIT_DOMAIN_COUNT=8
REPORT_RATE_LIMIT_CONTACT_COUNT=6
REPORT_MAX_REQUEST_BYTES=8192
# Optional comma-separated domain policies.
REPORT_BLOCKED_DOMAINS=
REPORT_DISPOSABLE_EMAIL_DOMAINS=
ENABLE_REAL_AI_CHECKS=false
ENABLE_MEME_IMAGE_GENERATION=false
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BOOK_CALL_URL=mailto:hello@launchclub.ai?subject=Buyer%20Visibility%20Sprint
REPORT_USE_MOCK_PROVIDERS=true
REPORT_USE_INLINE_WORKER=false
REPORT_USE_MEMORY_STORE=false
